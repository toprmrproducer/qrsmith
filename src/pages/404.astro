---
import Layout from '../layouts/Layout.astro';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<Layout
	title="Page Not Found — QRSmith"
	description="The page you're looking for doesn't exist."
	canonicalPath="/404"
>
	<section class="mx-auto max-w-xl text-center">
		<p class="font-[Sora] text-7xl font-extrabold text-[#c9982e]">404</p>
		<h1 class="mt-4 text-3xl font-bold tracking-tight text-[#221b10]">
			Page not found
		</h1>
		<p class="mt-4 text-[17px] leading-relaxed text-[#4a4234]">
			The page you're looking for doesn't exist or may have moved.
		</p>
		<a
			href={base}
			class="mt-8 inline-block rounded-xl bg-[#c9982e] px-6 py-3 text-[15px] font-semibold text-white transition hover:bg-[#b8860b]"
		>
			Back to QRSmith
		</a>
	</section>
</Layout>
