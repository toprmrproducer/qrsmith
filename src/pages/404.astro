---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Page Not Found — QRSmith"
	description="The page you're looking for doesn't exist."
	canonicalPath="/404"
>
	<section class="mx-auto max-w-xl text-center">
		<p class="font-[Fraunces] text-7xl font-700 text-[#C9982E]">404</p>
		<h1 class="mt-4 text-3xl font-700 tracking-tight text-[#2B2013]">
			Page not found
		</h1>
		<p class="mt-4 text-base leading-relaxed text-[#5C4F3D]">
			The page you're looking for doesn't exist or may have moved.
		</p>
		<a
			href={import.meta.env.BASE_URL}
			class="mt-8 inline-block rounded-xl bg-[#C9982E] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#B8860B]"
		>
			Back to QRSmith
		</a>
	</section>
</Layout>
