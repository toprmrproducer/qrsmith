---
import Layout from '../layouts/Layout.astro';

const lastUpdated = 'July 6, 2026';
---

<Layout
	title="Privacy Policy — QRSmith"
	description="QRSmith's privacy policy: everything runs client-side in your browser, we don't collect the text, images, or QR codes you generate."
	canonicalPath="/privacy"
>
	<section>
		<h1 class="text-4xl font-bold tracking-tight text-[#221b10]">Privacy Policy</h1>
		<p class="mt-3 text-[15px] text-[#8a7e68]">Last updated: {lastUpdated}</p>

		<div class="mt-8 flex flex-col gap-8 text-[17px] leading-relaxed text-[#4a4234]">
			<div>
				<h2 class="text-xl font-bold text-[#221b10]">What QRSmith does not collect</h2>
				<p class="mt-3">
					QRSmith generates QR codes entirely in your browser. The URL,
					text, WiFi details, contact card, or email you enter, any logo
					image you upload, and the QR code itself are processed locally
					on your device using JavaScript. None of that data is ever sent
					to, stored on, or logged by any server we operate.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-bold text-[#221b10]">Hosting and analytics</h2>
				<p class="mt-3">
					This site is a static site hosted on GitHub Pages. GitHub's
					infrastructure may log standard web server data (such as IP
					address and request timing) for security and operational
					purposes, governed by
					<a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" class="text-[#c9982e] underline hover:text-[#b8860b]">GitHub's own privacy statement</a>.
					We do not run any additional tracking scripts on top of that.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-bold text-[#221b10]">Advertising</h2>
				<p class="mt-3">
					If this site displays advertising (for example, through
					Google AdSense), the ad provider may use cookies or similar
					technologies to serve relevant ads and measure performance.
					You can control ad personalization through your browser
					settings or via
					<a href="https://adssettings.google.com/" class="text-[#c9982e] underline hover:text-[#b8860b]">Google's Ads Settings</a>.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-bold text-[#221b10]">Cookies</h2>
				<p class="mt-3">
					QRSmith itself does not set any cookies. Any cookies present
					on this site come from hosting infrastructure or advertising
					partners, not from the QR generation tool.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-bold text-[#221b10]">Contact</h2>
				<p class="mt-3">
					Questions about this policy can be sent to
					<a href="mailto:hello@qrsmith.app" class="text-[#c9982e] underline hover:text-[#b8860b]">hello@qrsmith.app</a>.
				</p>
			</div>
		</div>
	</section>
</Layout>
