---
import Layout from '../layouts/Layout.astro';

const lastUpdated = 'July 4, 2026';
---

<Layout
	title="Privacy Policy — QRSmith"
	description="QRSmith's privacy policy: everything runs client-side in your browser, we don't collect the text, images, or QR codes you generate."
	canonicalPath="/privacy"
>
	<section class="mx-auto max-w-2xl">
		<h1 class="text-4xl font-700 tracking-tight text-[#2B2013]">Privacy Policy</h1>
		<p class="mt-3 text-sm text-[#5C4F3D]/70">Last updated: {lastUpdated}</p>

		<div class="mt-8 flex flex-col gap-8 text-base leading-relaxed text-[#5C4F3D]">
			<div>
				<h2 class="text-xl font-600 text-[#2B2013]">What QRSmith does not collect</h2>
				<p class="mt-3">
					QRSmith generates QR codes entirely in your browser. The URL
					or text you type, any logo image you upload, and the QR code
					itself are processed locally on your device using
					JavaScript. None of that data is ever sent to, stored on, or
					logged by any server we operate.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-600 text-[#2B2013]">Hosting and analytics</h2>
				<p class="mt-3">
					This site is a static site hosted on Netlify. Netlify's
					infrastructure may log standard web server data (such as IP
					address and request timing) for security and operational
					purposes, governed by
					<a href="https://www.netlify.com/privacy/" class="text-[#C9982E] underline hover:text-[#B8860B]">Netlify's own privacy policy</a>.
					We do not run any additional tracking scripts on top of that.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-600 text-[#2B2013]">Advertising</h2>
				<p class="mt-3">
					If this site displays advertising (for example, through
					Google AdSense), the ad provider may use cookies or similar
					technologies to serve relevant ads and measure performance.
					You can control ad personalization through your browser
					settings or via
					<a href="https://adssettings.google.com/" class="text-[#C9982E] underline hover:text-[#B8860B]">Google's Ads Settings</a>.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-600 text-[#2B2013]">Cookies</h2>
				<p class="mt-3">
					QRSmith itself does not set any cookies. Any cookies present
					on this site come from hosting infrastructure or advertising
					partners, not from the QR generation tool.
				</p>
			</div>

			<div>
				<h2 class="text-xl font-600 text-[#2B2013]">Contact</h2>
				<p class="mt-3">
					Questions about this policy can be sent to
					<a href="mailto:hello@qrsmith.app" class="text-[#C9982E] underline hover:text-[#B8860B]">hello@qrsmith.app</a>.
				</p>
			</div>
		</div>
	</section>
</Layout>
