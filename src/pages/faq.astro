---
import Layout from '../layouts/Layout.astro';

const faqs = [
	{
		q: 'Is QRSmith really free?',
		a: 'Yes. There is no signup, no paywall, and no watermark on the QR codes you download.',
	},
	{
		q: 'Do my QR codes expire?',
		a: 'No. QRSmith generates static QR codes that encode your text or URL directly into the code pattern itself. They never expire and never rely on any tracking redirect service, so they will keep working forever, even if QRSmith disappears tomorrow.',
	},
	{
		q: 'Is it safe to add a logo to the middle of my QR code?',
		a: "Yes, within reason. QR codes include built-in error correction, so they can still be read correctly even if part of the pattern is obscured. QRSmith automatically switches to the highest error-correction level whenever a logo is present, and caps the logo size so the code stays scannable. Always test a printed code with your phone's camera before using it at scale.",
	},
	{
		q: 'Does QRSmith store the URLs or images I use?',
		a: 'No. Everything is generated client-side in your browser using JavaScript. Nothing you type or upload is sent to a server, logged, or stored anywhere.',
	},
	{
		q: 'What file formats can I download?',
		a: 'You can download your QR code as a PNG (best for most uses, including print) or an SVG (a scalable vector, ideal if you need to resize it to a very large size, like a billboard or storefront sign, without losing quality).',
	},
	{
		q: 'Can I use these QR codes commercially?',
		a: 'Yes. There are no usage restrictions or licensing fees on QR codes you generate with QRSmith.',
	},
	{
		q: 'Why does my logo make the QR code harder to scan sometimes?',
		a: "If a logo is too large relative to the QR code, it can cover too much of the encoded pattern for a scanner to recover. Keep initials or logos modest in size, use higher-contrast colors between the dots and background, and always test the final code with a real phone camera before printing it widely.",
	},
];
---

<Layout
	title="FAQ — QRSmith"
	description="Frequently asked questions about generating styled QR codes with logos using QRSmith."
	canonicalPath="/faq"
>
	<section class="mx-auto max-w-2xl">
		<h1 class="text-4xl font-700 tracking-tight text-[#2B2013]">
			Frequently Asked Questions
		</h1>

		<div class="mt-10 flex flex-col gap-8">
			{
				faqs.map((item) => (
					<div class="rounded-xl border border-[#E8DFC8] bg-white p-6 shadow-sm">
						<h2 class="text-lg font-600 text-[#2B2013]">{item.q}</h2>
						<p class="mt-3 text-base leading-relaxed text-[#5C4F3D]">
							{item.a}
						</p>
					</div>
				))
			}
		</div>
	</section>
</Layout>
