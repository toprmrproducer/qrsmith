---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="QRSmith — Styled QR Code Generator With Logo"
	description="Turn any URL or text into a styled QR code with custom colors, dot styles, and an embedded logo or initials — no signup, 100% client-side, free."
	canonicalPath="/"
>
	<section class="text-center">
		<h1 class="text-4xl font-700 tracking-tight text-[#2B2013] sm:text-5xl">
			Turn any link into a <span class="text-[#C9982E]">QR code</span> you'd
			actually put on a card.
		</h1>
		<p class="mx-auto mt-5 max-w-2xl text-lg text-[#5C4F3D]">
			Style the dots, pick your colors, drop your logo in the center — and
			download a crisp PNG or SVG. Live preview, no signup, nothing ever
			leaves your browser.
		</p>
	</section>

	<section class="mx-auto mt-8 max-w-2xl text-center text-sm leading-relaxed text-[#5C4F3D]/80">
		<p>
			The preview updates as you type. Everything &mdash; the QR encoding,
			the styling, and the logo embedding &mdash; happens directly in your
			browser with the <strong class="font-semibold text-[#2B2013]">qr-code-styling</strong>
			library. QR codes use built-in error correction, so a logo covering
			the center still scans fine as long as it doesn't get too large.
		</p>
	</section>

	<section id="generator" class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-8 scroll-mt-24 lg:grid-cols-2">
		<!-- Controls -->
		<div class="flex flex-col gap-6">
			<div class="rounded-xl border border-[#E8DFC8] bg-white p-6 shadow-sm">
				<label
					for="qr-text"
					class="block text-sm font-medium text-[#2B2013]"
				>
					URL or text
				</label>
				<textarea
					id="qr-text"
					rows="3"
					placeholder="https://example.com"
					class="mt-2 w-full resize-y rounded-xl border border-[#E8DFC8] bg-white p-3 text-sm text-[#2B2013] placeholder:text-[#5C4F3D]/40 focus:border-[#C9982E] focus:outline-none focus:ring-1 focus:ring-[#C9982E]"
				></textarea>
			</div>

			<div class="rounded-xl border border-[#E8DFC8] bg-white p-6 shadow-sm">
				<h2 class="font-[Inter] text-sm font-semibold text-[#2B2013]">Style</h2>

				<div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
					<div>
						<label
							for="dot-style"
							class="block text-xs font-medium tracking-wide text-[#5C4F3D]/70 uppercase"
						>
							Dot style
						</label>
						<select
							id="dot-style"
							class="mt-2 w-full rounded-xl border border-[#E8DFC8] bg-white px-3 py-2 text-sm text-[#2B2013] focus:border-[#C9982E] focus:outline-none focus:ring-1 focus:ring-[#C9982E]"
						>
							<option value="square">Square</option>
							<option value="dots">Dots</option>
							<option value="rounded">Rounded</option>
							<option value="classy">Classy</option>
							<option value="classy-rounded">Classy rounded</option>
							<option value="extra-rounded">Extra rounded</option>
						</select>
					</div>

					<div>
						<label
							for="corner-style"
							class="block text-xs font-medium tracking-wide text-[#5C4F3D]/70 uppercase"
						>
							Corner style
						</label>
						<select
							id="corner-style"
							class="mt-2 w-full rounded-xl border border-[#E8DFC8] bg-white px-3 py-2 text-sm text-[#2B2013] focus:border-[#C9982E] focus:outline-none focus:ring-1 focus:ring-[#C9982E]"
						>
							<option value="square">Square</option>
							<option value="dot">Dot</option>
							<option value="extra-rounded">Extra rounded</option>
						</select>
					</div>

					<div>
						<label
							for="dot-color"
							class="block text-xs font-medium tracking-wide text-[#5C4F3D]/70 uppercase"
						>
							Dot color
						</label>
						<div class="mt-2 flex items-center gap-2">
							<input
								id="dot-color"
								type="color"
								value="#2B2013"
								class="h-9 w-12 cursor-pointer rounded-lg border border-[#E8DFC8] bg-white p-1"
							/>
							<span
								id="dot-color-label"
								class="text-xs text-[#5C4F3D]/70">#2B2013</span
							>
						</div>
					</div>

					<div>
						<label
							for="bg-color"
							class="block text-xs font-medium tracking-wide text-[#5C4F3D]/70 uppercase"
						>
							Background color
						</label>
						<div class="mt-2 flex items-center gap-2">
							<input
								id="bg-color"
								type="color"
								value="#ffffff"
								class="h-9 w-12 cursor-pointer rounded-lg border border-[#E8DFC8] bg-white p-1"
							/>
							<span
								id="bg-color-label"
								class="text-xs text-[#5C4F3D]/70">#ffffff</span
							>
						</div>
					</div>
				</div>
			</div>

			<div class="rounded-xl border border-[#E8DFC8] bg-white p-6 shadow-sm">
				<h2 class="font-[Inter] text-sm font-semibold text-[#2B2013]">
					Center logo <span class="font-normal text-[#5C4F3D]/50"
						>(optional)</span
					>
				</h2>

				<div class="mt-4 flex flex-wrap gap-2" role="tablist">
					<button
						id="logo-tab-none"
						type="button"
						class="logo-tab rounded-xl border border-[#C9982E] bg-[#C9982E] px-3 py-1.5 text-xs font-semibold text-white"
						data-mode="none"
					>
						None
					</button>
					<button
						id="logo-tab-upload"
						type="button"
						class="logo-tab rounded-xl border border-[#E8DFC8] bg-white px-3 py-1.5 text-xs font-semibold text-[#5C4F3D] transition hover:border-[#C9982E] hover:text-[#B8860B]"
						data-mode="upload"
					>
						Upload image
					</button>
					<button
						id="logo-tab-initials"
						type="button"
						class="logo-tab rounded-xl border border-[#E8DFC8] bg-white px-3 py-1.5 text-xs font-semibold text-[#5C4F3D] transition hover:border-[#C9982E] hover:text-[#B8860B]"
						data-mode="initials"
					>
						Type initials
					</button>
				</div>

				<div id="logo-panel-upload" class="mt-4 hidden">
					<input
						id="logo-file"
						type="file"
						accept="image/*"
						class="block w-full text-xs text-[#5C4F3D] file:mr-3 file:rounded-xl file:border-0 file:bg-[#C9982E] file:px-3 file:py-2 file:text-xs file:font-semibold file:text-white hover:file:bg-[#B8860B]"
					/>
				</div>

				<div id="logo-panel-initials" class="mt-4 hidden">
					<div class="flex flex-wrap items-end gap-4">
						<div>
							<label
								for="initials-input"
								class="block text-xs font-medium tracking-wide text-[#5C4F3D]/70 uppercase"
							>
								Initials
							</label>
							<input
								id="initials-input"
								type="text"
								maxlength="3"
								placeholder="AB"
								class="mt-2 w-24 rounded-xl border border-[#E8DFC8] bg-white px-3 py-2 text-center text-sm font-semibold text-[#2B2013] uppercase focus:border-[#C9982E] focus:outline-none focus:ring-1 focus:ring-[#C9982E]"
							/>
						</div>
						<div>
							<label
								for="initials-bg-color"
								class="block text-xs font-medium tracking-wide text-[#5C4F3D]/70 uppercase"
							>
								Badge color
							</label>
							<input
								id="initials-bg-color"
								type="color"
								value="#C9982E"
								class="mt-2 h-9 w-12 cursor-pointer rounded-lg border border-[#E8DFC8] bg-white p-1"
							/>
						</div>
					</div>
				</div>

				<div
					id="logo-error"
					class="mt-3 hidden text-xs text-red-600"
				></div>
			</div>
		</div>

		<!-- Preview -->
		<div class="flex flex-col items-center">
			<div
				class="flex w-full flex-col items-center rounded-xl border border-[#E8DFC8] bg-white p-8 shadow-sm"
			>
				<div
					id="qr-preview"
					class="flex min-h-[280px] items-center justify-center"
				>
				</div>
				<p id="qr-empty-hint" class="mt-2 text-center text-xs text-[#5C4F3D]/50">
					Start typing above to generate your QR code.
				</p>
			</div>

			<div class="mt-6 flex w-full flex-col gap-3 sm:flex-row">
				<button
					id="download-png"
					disabled
					class="flex-1 rounded-xl bg-[#C9982E] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#B8860B] disabled:cursor-not-allowed disabled:bg-[#E8DFC8] disabled:text-[#5C4F3D]/50"
				>
					Download PNG
				</button>
				<button
					id="download-svg"
					disabled
					class="flex-1 rounded-xl border border-[#E8DFC8] bg-white px-6 py-3 text-sm font-semibold text-[#2B2013] transition hover:border-[#C9982E] hover:text-[#B8860B] disabled:cursor-not-allowed disabled:border-[#E8DFC8] disabled:text-[#5C4F3D]/30"
				>
					Download SVG
				</button>
			</div>
		</div>
	</section>

	<script>
		import QRCodeStyling from 'qr-code-styling';
		import type {
			DotType,
			CornerSquareType,
			FileExtension,
		} from 'qr-code-styling';

		const escapeHtml = (str: string): string =>
			str
				.replace(/&/g, '&amp;')
				.replace(/</g, '&lt;')
				.replace(/>/g, '&gt;');

		const qrText = document.getElementById('qr-text') as HTMLTextAreaElement;
		const dotStyleSelect = document.getElementById(
			'dot-style',
		) as HTMLSelectElement;
		const cornerStyleSelect = document.getElementById(
			'corner-style',
		) as HTMLSelectElement;
		const dotColorInput = document.getElementById(
			'dot-color',
		) as HTMLInputElement;
		const dotColorLabel = document.getElementById(
			'dot-color-label',
		) as HTMLSpanElement;
		const bgColorInput = document.getElementById(
			'bg-color',
		) as HTMLInputElement;
		const bgColorLabel = document.getElementById(
			'bg-color-label',
		) as HTMLSpanElement;

		const logoTabNone = document.getElementById(
			'logo-tab-none',
		) as HTMLButtonElement;
		const logoTabUpload = document.getElementById(
			'logo-tab-upload',
		) as HTMLButtonElement;
		const logoTabInitials = document.getElementById(
			'logo-tab-initials',
		) as HTMLButtonElement;
		const logoTabs = [logoTabNone, logoTabUpload, logoTabInitials];

		const logoPanelUpload = document.getElementById(
			'logo-panel-upload',
		) as HTMLDivElement;
		const logoPanelInitials = document.getElementById(
			'logo-panel-initials',
		) as HTMLDivElement;
		const logoFile = document.getElementById('logo-file') as HTMLInputElement;
		const initialsInput = document.getElementById(
			'initials-input',
		) as HTMLInputElement;
		const initialsBgColor = document.getElementById(
			'initials-bg-color',
		) as HTMLInputElement;
		const logoError = document.getElementById('logo-error') as HTMLDivElement;

		const qrPreview = document.getElementById('qr-preview') as HTMLDivElement;
		const qrEmptyHint = document.getElementById(
			'qr-empty-hint',
		) as HTMLParagraphElement;
		const downloadPngBtn = document.getElementById(
			'download-png',
		) as HTMLButtonElement;
		const downloadSvgBtn = document.getElementById(
			'download-svg',
		) as HTMLButtonElement;

		type LogoMode = 'none' | 'upload' | 'initials';
		let logoMode: LogoMode = 'none';
		let uploadedLogoDataUrl: string | null = null;
		let debounceHandle: ReturnType<typeof setTimeout> | null = null;

		let qrCode: QRCodeStyling | null = null;

		const setLogoError = (message: string | null) => {
			if (!message) {
				logoError.classList.add('hidden');
				logoError.textContent = '';
				return;
			}
			logoError.classList.remove('hidden');
			// Use textContent (not innerHTML) for anything derived from user
			// input; escapeHtml is kept as the standing helper for any future
			// innerHTML usage across this tool family.
			logoError.textContent = escapeHtml(message);
		};

		const setActiveTab = (mode: LogoMode) => {
			logoMode = mode;
			logoTabs.forEach((tab) => {
				const isActive = tab.dataset.mode === mode;
				tab.classList.toggle('bg-[#C9982E]', isActive);
				tab.classList.toggle('text-white', isActive);
				tab.classList.toggle('border-[#C9982E]', isActive);
				tab.classList.toggle('bg-white', !isActive);
				tab.classList.toggle('text-[#5C4F3D]', !isActive);
				tab.classList.toggle('border-[#E8DFC8]', !isActive);
			});
			logoPanelUpload.classList.toggle('hidden', mode !== 'upload');
			logoPanelInitials.classList.toggle('hidden', mode !== 'initials');
			setLogoError(null);
		};

		logoTabNone.addEventListener('click', () => {
			setActiveTab('none');
			scheduleRender();
		});
		logoTabUpload.addEventListener('click', () => {
			setActiveTab('upload');
			scheduleRender();
		});
		logoTabInitials.addEventListener('click', () => {
			setActiveTab('initials');
			scheduleRender();
		});

		// Render typed initials onto a small canvas, producing a data URL that
		// qr-code-styling can use as its "image" option just like an uploaded logo.
		const renderInitialsToDataUrl = (
			initials: string,
			badgeColor: string,
		): string | null => {
			const cleaned = initials.trim().slice(0, 3);
			if (cleaned === '') return null;

			const size = 200;
			const canvas = document.createElement('canvas');
			canvas.width = size;
			canvas.height = size;
			const ctx = canvas.getContext('2d');
			if (!ctx) return null;

			// Circular badge background
			ctx.fillStyle = badgeColor;
			ctx.beginPath();
			ctx.arc(size / 2, size / 2, size / 2, 0, Math.PI * 2);
			ctx.fill();

			// Text
			ctx.fillStyle = '#ffffff';
			ctx.font = `700 ${cleaned.length === 1 ? 110 : cleaned.length === 2 ? 82 : 62}px system-ui, -apple-system, "Segoe UI", sans-serif`;
			ctx.textAlign = 'center';
			ctx.textBaseline = 'middle';
			ctx.fillText(cleaned.toUpperCase(), size / 2, size / 2 + 6);

			return canvas.toDataURL('image/png');
		};

		logoFile.addEventListener('change', () => {
			const file = logoFile.files?.[0];
			if (!file) {
				uploadedLogoDataUrl = null;
				scheduleRender();
				return;
			}
			if (!file.type.startsWith('image/')) {
				setLogoError('Please choose an image file.');
				return;
			}
			const reader = new FileReader();
			reader.onload = () => {
				uploadedLogoDataUrl =
					typeof reader.result === 'string' ? reader.result : null;
				setLogoError(null);
				scheduleRender();
			};
			reader.onerror = () => {
				setLogoError('Could not read that image file.');
			};
			reader.readAsDataURL(file);
		});

		initialsInput.addEventListener('input', () => {
			initialsInput.value = initialsInput.value.toUpperCase();
			scheduleRender();
		});
		initialsBgColor.addEventListener('input', scheduleRender);

		dotColorInput.addEventListener('input', () => {
			dotColorLabel.textContent = dotColorInput.value;
			scheduleRender();
		});
		bgColorInput.addEventListener('input', () => {
			bgColorLabel.textContent = bgColorInput.value;
			scheduleRender();
		});
		dotStyleSelect.addEventListener('change', scheduleRender);
		cornerStyleSelect.addEventListener('change', scheduleRender);
		qrText.addEventListener('input', scheduleRender);

		function scheduleRender() {
			if (debounceHandle) clearTimeout(debounceHandle);
			debounceHandle = setTimeout(render, 250);
		}

		function getLogoImage(): string | undefined {
			if (logoMode === 'upload' && uploadedLogoDataUrl) {
				return uploadedLogoDataUrl;
			}
			if (logoMode === 'initials') {
				const dataUrl = renderInitialsToDataUrl(
					initialsInput.value,
					initialsBgColor.value,
				);
				return dataUrl ?? undefined;
			}
			return undefined;
		}

		function render() {
			const text = qrText.value.trim();

			if (text === '') {
				qrPreview.innerHTML = '';
				qrEmptyHint.classList.remove('hidden');
				downloadPngBtn.disabled = true;
				downloadSvgBtn.disabled = true;
				qrCode = null;
				return;
			}

			qrEmptyHint.classList.add('hidden');

			const image = getLogoImage();

			const options = {
				width: 280,
				height: 280,
				type: 'canvas' as const,
				data: text,
				margin: 8,
				qrOptions: {
					errorCorrectionLevel: (image ? 'H' : 'M') as 'H' | 'M',
				},
				imageOptions: {
					crossOrigin: 'anonymous',
					margin: 6,
					hideBackgroundDots: true,
					imageSize: 0.4,
				},
				dotsOptions: {
					type: dotStyleSelect.value as DotType,
					color: dotColorInput.value,
				},
				cornersSquareOptions: {
					type: cornerStyleSelect.value as CornerSquareType,
					color: dotColorInput.value,
				},
				backgroundOptions: {
					color: bgColorInput.value,
				},
				image,
			};

			if (!qrCode) {
				qrCode = new QRCodeStyling(options);
				qrPreview.innerHTML = '';
				qrCode.append(qrPreview);
			} else {
				qrCode.update(options);
			}

			downloadPngBtn.disabled = false;
			downloadSvgBtn.disabled = false;
		}

		const safeFileBase = (text: string): string => {
			// Not rendered to the DOM, but keep filenames clean/predictable anyway.
			const slug = text
				.trim()
				.toLowerCase()
				.replace(/^https?:\/\//, '')
				.replace(/[^a-z0-9]+/g, '-')
				.replace(/^-+|-+$/g, '')
				.slice(0, 40);
			return slug || 'qr-code';
		};

		const downloadAs = async (extension: FileExtension) => {
			if (!qrCode) return;
			const name = safeFileBase(qrText.value);
			await qrCode.download({ name, extension });
		};

		downloadPngBtn.addEventListener('click', () => downloadAs('png'));
		downloadSvgBtn.addEventListener('click', () => downloadAs('svg'));
	</script>
</Layout>
