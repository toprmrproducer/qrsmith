---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	canonicalPath?: string;
}

const { title, description, canonicalPath = '/' } = Astro.props;
const siteUrl = 'https://toprmrproducer.github.io';
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const canonical = new URL(`${base}${canonicalPath.replace(/^\//, '')}`, siteUrl).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="generator" content={Astro.generator} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Sora:wght@700;800&family=Manrope:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<style>
			/*
			 * Reserved AdSense slots. Kept invisible (zero height, no border)
			 * until a real <ins class="adsbygoogle"> is dropped inside. Empty
			 * placeholder ad boxes can hurt AdSense approval, so nothing renders
			 * until the slot is actually populated. Sized to minimize layout
			 * shift once filled.
			 */
			.ad-slot:empty {
				min-height: 0;
				height: 0;
				overflow: hidden;
			}
			.ad-slot {
				width: 100%;
			}
			.ad-skyscraper {
				width: 160px;
			}
		</style>
	</head>
	<body class="min-h-screen bg-[#ffffff] font-[Manrope] text-[#4a4234] antialiased">
		<header class="border-b border-[#eae4d6]">
			<nav class="mx-auto flex max-w-[820px] items-center justify-between px-6 py-5">
				<a
					href={base}
					class="font-[Sora] text-xl font-bold tracking-tight text-[#221b10]"
				>
					QR<span class="text-[#c9982e]">Smith</span>
				</a>
				<a
					href={`${base}#generator`}
					class="rounded-xl bg-[#c9982e] px-4 py-2 text-[15px] font-semibold text-white transition hover:bg-[#b8860b]"
				>
					Make a QR code
				</a>
			</nav>
		</header>

		<!-- Top leaderboard ad slot (reserved, invisible until filled) -->
		<div
			class="ad-slot ad-leaderboard mx-auto"
			data-ad-slot="leaderboard"
			style="max-width:970px;min-height:0"
		>
			<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
		</div>

		<!--
		 Ad-ready row: [left skyscraper][820px content column][right skyscraper].
		 The two <aside> skyscrapers only appear at >=1280px (xl), sitting in the
		 empty gutters beside the hard-capped 820px column. Below xl they are
		 hidden and the column stays centered with generous side padding.
		-->
		<div class="mx-auto flex max-w-[1400px] items-start justify-center gap-8 px-6">
			<aside
				class="ad-slot ad-skyscraper hidden shrink-0 xl:block"
				data-ad-slot="skyscraper-left"
				style="position:sticky;top:120px;min-height:0"
			>
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</aside>

			<main class="mx-auto w-full max-w-[820px] px-0 pt-24 pb-28">
				<slot />
			</main>

			<aside
				class="ad-slot ad-skyscraper hidden shrink-0 xl:block"
				data-ad-slot="skyscraper-right"
				style="position:sticky;top:120px;min-height:0"
			>
				<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
			</aside>
		</div>

		<!-- Bottom in-article ad slot (reserved, invisible until filled) -->
		<div
			class="ad-slot ad-in-article mx-auto"
			data-ad-slot="in-article"
			style="max-width:728px;min-height:0"
		>
			<!-- AdSense: paste responsive <ins class="adsbygoogle"> here -->
		</div>

		<footer class="mt-24 border-t border-[#eae4d6]">
			<div class="mx-auto max-w-[820px] px-6 py-10 text-[15px] text-[#4a4234]">
				<div class="flex flex-wrap items-center justify-between gap-4">
					<p class="font-[Sora] text-base font-bold text-[#221b10]">
						QRSmith
					</p>
					<div class="flex gap-6">
						<a href={`${base}about`} class="transition hover:text-[#b8860b]">About</a>
						<a href={`${base}privacy`} class="transition hover:text-[#b8860b]">Privacy Policy</a>
						<a href={`${base}faq`} class="transition hover:text-[#b8860b]">FAQ</a>
					</div>
				</div>
				<p class="mt-6 text-[#8a7e68]">
					Everything runs locally in your browser. Nothing you type or
					upload is ever sent to a server.
				</p>
				<p class="mt-4 text-[#8a7e68]">
					&copy; {new Date().getFullYear()} QRSmith. All rights reserved.
				</p>
			</div>
		</footer>
	</body>
</html>
